<?xml version="1.0"?>
<robot name="simple_arm">
  <group name="arm">
    <chain base_link="base_link" tip_link="tool_link"/>
  </group>

  <group name="tool">
    <link name="tool_link"/>
  </group>

  <group_state name="ready" group="arm">
    <joint name="shoulder_joint" value="0.0"/>
    <joint name="elbow_joint" value="0.3"/>
  </group_state>

  <end_effector name="tool" parent_link="tool_link" group="tool" parent_group="arm"/>
</robot>
